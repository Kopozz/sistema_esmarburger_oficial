{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    {
      "src": "/(css|includes)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/$",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/$1"
    }
  ]
}
