{
  "version": 2,
  "builds": [
    {
      "src": "**/*.php",
      "use": "vercel-php@0.8.0"
    },
    {
      "src": "css/**/*.css",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(css|database|includes)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
